{
  "version": "2.1.0",
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.18.0",
          "fullName": "CodeQL CLI",
          "rules": [
            {
              "id": "py/unsafe-cyclic-import",
              "name": "py/unsafe-cyclic-import",
              "defaultConfiguration": { "level": "error" },
              "properties": {
                "cwe": ["CWE-1104"],
                "tags": ["security", "python"]
              }
            },
            {
              "id": "py/path-injection",
              "name": "py/path-injection",
              "defaultConfiguration": { "level": "warning" },
              "properties": {
                "cwe": ["CWE-22", "CWE-73"],
                "tags": ["security", "python"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "py/unsafe-cyclic-import",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "Unsafe cyclic import detected. This module imports itself transitively, which can cause initialization order bugs and crashes."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/utils/loader.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 1,
                  "startColumn": 1,
                  "endLine": 1,
                  "endColumn": 50
                }
              }
            }
          ],
          "properties": {
            "severity": "error"
          }
        },
        {
          "ruleId": "py/path-injection",
          "ruleIndex": 1,
          "level": "warning",
          "message": {
            "text": "Path injection: user-controlled data is used in a file system operation without sanitization. An attacker could read or write arbitrary files."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/api/files.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 42,
                  "startColumn": 5,
                  "endLine": 42,
                  "endColumn": 80
                }
              }
            }
          ],
          "properties": {
            "severity": "warning"
          }
        }
      ],
      "language": "en-US"
    }
  ]
}
